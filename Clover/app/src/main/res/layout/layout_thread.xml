<!-- This file controls the Reply FAB and the top/bottom navigation FABs -->
<org.otacoo.chan.ui.layout.ThreadLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <org.otacoo.chan.ui.view.LoadView
        android:id="@+id/loadview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- fab_container: layout_marginBottom controls bottom offset of the whole FAB stack. -->
    <LinearLayout
        android:id="@+id/fab_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        tools:ignore="RtlHardcoded">

        <!-- top_button: layout_marginBottom controls gap to the button below. -->
        <org.otacoo.chan.ui.view.HidingFloatingActionButton
            android:id="@+id/top_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:layout_marginBottom="2dp"
            app:borderWidth="0dp"
            app:elevation="4dp"
            app:pressedTranslationZ="8dp"
            app:useCompatPadding="true"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_expand_less_white_24dp"
            android:visibility="gone" />

        <!-- bottom_button: layout_marginBottom controls gap to Reply FAB. -->
        <org.otacoo.chan.ui.view.HidingFloatingActionButton
            android:id="@+id/bottom_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:layout_marginBottom="2dp"
            app:borderWidth="0dp"
            app:elevation="4dp"
            app:pressedTranslationZ="8dp"
            app:useCompatPadding="true"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_expand_more_white_24dp"
            android:visibility="gone" />

        <org.otacoo.chan.ui.view.HidingFloatingActionButton
            android:id="@+id/reply_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            app:borderWidth="0dp"
            app:elevation="4dp"
            app:pressedTranslationZ="8dp"
            app:useCompatPadding="true"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_create_white_24dp" />

    </LinearLayout>

    <!-- New posts notification bar -->
    <LinearLayout
        android:id="@+id/new_posts_notification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:background="#FF323232"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/new_posts_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/new_posts_action"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:text="@string/thread_new_posts_goto"
            android:textAllCaps="true"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</org.otacoo.chan.ui.layout.ThreadLayout>
