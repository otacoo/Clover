<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="?backcolor"
    android:gravity="center_vertical"
    android:layout_marginBottom="1dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cookie_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="?text_color_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/cookie_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?text_color_secondary"
            android:textSize="13sp"
            android:paddingTop="4dp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/delete_cookie"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_clear_black_24dp"
        android:tint="?text_color_secondary"
        android:background="?android:selectableItemBackgroundBorderless"
        android:contentDescription="Delete cookie" />

</LinearLayout>
